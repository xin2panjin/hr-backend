# ==============================
# 数据库配置
# ==============================
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hr_system
DB_AGENT_NAME=hr_system_agent

# ==============================
# JWT 与登录态配置
# ==============================
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ==============================
# Redis 与业务过期时间配置
# ==============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6389
INVITE_CODE_EXPIRE_SECONDS=172800

# ==============================
# 邮件发送与邮箱轮询配置
# ==============================
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=change-me
MAIL_PORT=587
MAIL_SERVER=smtp.qq.com
MAIL_FROM_NAME=X公司HR部门
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
ENABLE_EMAIL_POLLING=false
EMAIL_BOT_IMAP_HOST=imap.qq.com
EMAIL_BOT_SMTP_HOST=smtp.qq.com

# ==============================
# 大模型与 Embedding 配置
# ==============================
DASHSCOPE_API_KEY=change-me
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
DEEPSEEK_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==============================
# 钉钉与 OCR 外部服务配置
# ==============================
DINGTALK_APP_KEY=change-me
DINGTALK_APP_SECRET=change-me
PADDLE_OCR_ACCESS_TOKEN=change-me

# ==============================
# Web 服务与运行环境配置
# ==============================
BACKEND_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5173
RESUME_DIR=upload
DEBUG=false

# ==============================
# Milvus 向量库配置
# ==============================
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
# 候选人检索 Collection，支持 dense、BM25 和 hybrid。
MILVUS_CANDIDATE_COLLECTION=candidate_profiles

# 混合检索候选池参数：稠密召回、BM25 召回及融合后保留数量
# 可选值：dense、sparse、hybrid；默认使用 Milvus 原生 RRF 融合
TALENT_SEARCH_RETRIEVAL_MODE=hybrid
TALENT_SEARCH_DENSE_RECALL_K=30
TALENT_SEARCH_SPARSE_RECALL_K=30
TALENT_SEARCH_HYBRID_LIMIT=30

# 是否启用融合结果的二次重排；默认关闭
TALENT_SEARCH_RERANK_ENABLED=false
# 可选值：noop、cohere_compatible、dashscope_native。
# 后两个值表示 API 协议而非云厂商。
TALENT_SEARCH_RERANK_PROVIDER=noop
# cohere_compatible 可用于 DashScope qwen3-rerank、Cohere、Jina 及兼容 /rerank 协议的服务。
# dashscope_native 用于 input/parameters 原生协议的服务（例如已开通的 bge-reranker-v2-m3 服务）。
TALENT_SEARCH_RERANK_MODEL=qwen3-rerank
# 填写完整 Rerank 接口地址，而非聊天或 Embedding 的 Base URL。
TALENT_SEARCH_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
TALENT_SEARCH_RERANK_API_KEY=
TALENT_SEARCH_RERANK_TIMEOUT_SECONDS=20
TALENT_SEARCH_RERANK_MAX_PROFILE_CHARS=1500

# 稠密向量维度，必须与 Embedding 模型实际输出一致
MILVUS_CANDIDATE_VECTOR_DIM=1024
